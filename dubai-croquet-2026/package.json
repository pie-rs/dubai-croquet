{
  "name": "monolith-industries",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "tina:dev": "tinacms dev -c \"next dev\"",
    "build": "next build",
    "tina:build": "tinacms build --skip-cloud-checks",
    "migrate:legacy-content": "tsx scripts/migrate-legacy-content.ts",
    "start": "next start",
    "lint": "eslint src tina drizzle.config.ts next.config.ts playwright.config.ts vitest.config.ts eslint.config.mjs postcss.config.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:circular": "madge --circular --extensions ts,tsx src/",
    "worker": "dotenv -e .env.local -- tsx src/worker/index.ts",
    "prepare": "sh -c 'root=$(git rev-parse --show-toplevel 2>/dev/null || true); if [ \"$root\" != \"$PWD\" ]; then echo \"Skipping husky install from nested project\"; exit 0; fi; husky'"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@sentry/nextjs": "^10.44.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.7",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "pg-boss": "^12.14.0",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tinacms": "^3.7.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@tinacms/cli": "^2.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^8.0.8",
    "vitest": "^4.1.0"
  }
}
