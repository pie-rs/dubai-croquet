                "title": "The Clements Cup 2023 Season Opener",
                "sections": [
                    {
                        "elementId": "",
                        "colors": "colors-h",
                        "title": "The 2023 Dubai Croquet Clements Cup",
                        "subtitle": "Brought to you by PIMMS and Frosé.",
                        "badge": {
                            "label": "The biggest thing since biggy smalls",
                            "elementId": "",
                            "styles": {
